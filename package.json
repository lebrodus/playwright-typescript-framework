{
  "name": "playwright-typescript-framework",
  "version": "1.0.0",
  "description": "Production-style end-to-end, API and web test automation framework built with Playwright and TypeScript (Page Object Model, fixtures, CI).",
  "author": "Lewis Babe Yaka",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "test": "playwright test",
    "test:e2e": "playwright test tests/e2e",
    "test:api": "playwright test tests/api",
    "test:web": "playwright test tests/web",
    "test:visual": "playwright test --project=visual",
    "test:visual:update": "playwright test --project=visual --update-snapshots",
    "test:headed": "playwright test --headed",
    "allure:generate": "allure generate allure-results --clean -o allure-report",
    "allure:open": "allure open allure-report",
    "allure:serve": "allure serve allure-results",
    "test:ui": "playwright test --ui",
    "test:chromium": "playwright test --project=chromium",
    "report": "playwright show-report",
    "codegen": "playwright codegen",
    "lint": "tsc --noEmit"
  },
  "keywords": [
    "playwright",
    "typescript",
    "test-automation",
    "e2e",
    "api-testing",
    "qa",
    "sdet",
    "page-object-model",
    "ci-cd"
  ],
  "devDependencies": {
    "@playwright/test": "^1.49.0",
    "@types/node": "^22.10.0",
    "allure-commandline": "^2.32.0",
    "allure-playwright": "^3.0.0",
    "typescript": "^5.7.0"
  }
}
