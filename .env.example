# Copy to `.env` (gitignored) to override credentials locally.
# All values are OPTIONAL - tests fall back to the services' public demo
# credentials when these are unset, so the project is clone-and-run.

# SauceDemo (https://www.saucedemo.com)
SAUCE_USERNAME=standard_user
SAUCE_PASSWORD=secret_sauce

# Restful Booker (https://restful-booker.herokuapp.com)
BOOKER_USERNAME=admin
BOOKER_PASSWORD=password123
